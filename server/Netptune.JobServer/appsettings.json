{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "System": "Warning"
    }
  },
  "Origin": "https://netptune.co.uk/",
  "CorsOrigins": [
    "https://netptune.co.uk"
  ],
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "netptune": "Host=localhost;Database=netptune;Username=postgres;",
    "netptune-jobs": "Host=localhost;Database=netptune-jobs;Username=postgres;",
    "redis": "localhost"
  },
  "Tokens": {
    "Issuer": "netptune.co.uk",
    "Audience": "netptune.co.uk",
    "ExpireDays": "5"
  },
  "Email": {
    "DefaultFromAddress": "support@netptune.co.uk",
    "DefaultFromDisplayName": "Netptune Support"
  },
  "Automation": {
    "Schedule": {
      "StartupDelay": "00:02:00",
      "RunInterval": "01:00:00"
    }
  },
  "Events": {
    "Consumer": {
      "FilterSubjects": [
        "netptune.search",
        "netptune.email",
        "netptune.automation"
      ]
    }
  }
}
