persistence:
  postgres:
    size: "40Gi"
  kafka:
    size: "40Gi"

parameters:
  client:
    # Internal cluster DNS — nginx proxies /api/ to this URL. No need to change unless overriding.
    api_url: "http://api-service:8080"

secrets:
  postgres:
    postgres_password: ""
  cache:
    cache_password: ""
  api:
    cache_password: ""
    postgres_password: ""
    signing_key: ""
    github_client_id: ""
    github_secret: ""
    github_callback: ""
    sendgrid_api_key: ""
    s3_bucket_name: ""
    s3_region: ""
    s3_access_key_id: ""
    s3_secret_access_key: ""
  jobs:
    cache_password: ""
    postgres_password: ""
    signing_key: ""
    sendgrid_api_key: ""
    s3_bucket_name: ""
    s3_region: ""
    s3_access_key_id: ""
    s3_secret_access_key: ""
