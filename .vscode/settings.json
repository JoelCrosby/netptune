{
  "files.exclude": {
    "**/*.csproj.user": true,
    "**/.DS_Store": true,
    "**/.git": true,
    "**/.idea": true,
    "**/.sonarlint": true,
    "**/.vs": true,
    "**/StyleCop.Cache": true,
    "**/bin": true,
    "**/dist": true,
    "**/node_modules": true,
    "**/pgdata": true,
    "**/obj": true,
    "**/.cache/**": true,
    "**/.angular/**": true,
    "**/.vite": true,
    "**/.solid-start": true,
    "**/.output": true,
    "**/.nitro": true,
    "**/*.rpyc": true,
    "**/*.rpa": true,
    "**/*.rpymc": true,
    "**/cache/": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/bazel-out/**": true,
    "**/dist/**": true,
    "**/node_modules/**": true,
    "**/.cache/**": true,
    "**/.angular/**": true,
    "**/.vite": true,
    "**/.solid-start": true,
    "**/.output": true,
    "**/.nitro": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/*.code-search": true,
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/bazel-out/**": true,
    "**/dist/**": true,
    "**/.cache/**": true,
    "**/.angular/**": true
  },
  "dotnet.defaultSolution": "server/Netptune.sln",
  "[typescript]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[html]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "css.customData": [".vscode/tailwind.json"],
  "tailwindCSS.includeLanguages": {
    "plaintext": "html"
  },
  "js/ts.preferences.quoteStyle": "single",
  "js/ts.preferences.importModuleSpecifier": "shortest",
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "js/ts.experimental.useTsgo": true,
  "files.insertFinalNewline": true,
  "css.validate": false
}
