{
  "files.exclude": {
    "**/*.csproj.user": true,
    "**/.DS_Store": true,
    "**/.git": true,
    "**/.idea": true,
    "**/.sonarlint": true,
    "**/.vs": true,
    "**/StyleCop.Cache": true,
    "**/bin": true,
    "**/dist": true,
    "**/node_modules": true,
    "**/pgdata": true,
    "**/obj": true,
    "**/.cache/**": true,
    "**/.angular/**": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/bazel-out/**": true,
    "**/dist/**": true,
    "**/node_modules/**": true,
    "**/.cache/**": true,
    "**/.angular/**": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/*.code-search": true,
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/bazel-out/**": true,
    "**/dist/**": true,
    "**/.cache/**": true,
    "**/.angular/**": true
  },
  "dotnet.defaultSolution": "server/Netptune.sln",
    "[typescript]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[scss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "css.customData": [".vscode/tailwind.json"],
  "scss.lint.unknownAtRules": "ignore",
  "[html]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
}
